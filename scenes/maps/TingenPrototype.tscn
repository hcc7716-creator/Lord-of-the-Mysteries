[node name="OldNeil" parent="NPCs" instance=ExtResource("3_npc")]
position = Vector2(760, -635)
npc_name = "老尼尔"
dialogue_text = "你终于来了。\n这起死亡案不像普通谋杀，现场留下了很轻的灵性波动。\n先调查异常死亡现场，再用灵视找出被遮蔽的污染残留。之后用灵摆确认方向。"
quest_to_offer = "quest_tingen_become_seer"
interaction_prompt = "按 E 与老尼尔交谈"

[node name="Locations" type="Node2D" parent="."]

[node name="ProtagonistResidence" parent="Locations" instance=ExtResource("5_location")]
position = Vector2(-830, -635)
location_id = "protagonist_residence"
location_name = "主角住所"
location_description = "一间临街的旧公寓。这里是你在雾城暂时落脚的地方；后续可扩展为休息、存档与私人线索板。"
interaction_prompt = "按 E 查看主角住所"

[node name="OfficialBureau" parent="Locations" instance=ExtResource("5_location")]
position = Vector2(620, -635)
location_id = "official_beyonder_bureau"
location_name = "官方非凡者据点"
location_description = "守灯人组织在雾城的办事处。这里管理异常案件、封印物申请与有限的非凡者协作。"
interaction_prompt = "按 E 查看官方据点"

[node name="DivinationClub" parent="Locations" instance=ExtResource("5_location")]
position = Vector2(-820, 35)
location_id = "divination_club"
location_name = "占卜俱乐部"
location_description = "一处对外宣称研究梦境与星象的私人会所。它既能提供传闻，也会遮掩真正的神秘学交流。"
interaction_prompt = "按 E 查看占卜俱乐部"

[node name="PoliceStation" parent="Locations" instance=ExtResource("5_location")]
position = Vector2(760, 30)
location_id = "police_station"
location_name = "警察局"
location_description = "普通案件和城市失踪报告都会汇集到这里。和警员建立关系，能获得正式委托与街区消息。"
interaction_prompt = "按 E 查看警察局"

[node name="Church" parent="Locations" instance=ExtResource("5_location")]
position = Vector2(645, 740)
location_id = "church"
location_name = "教堂"
location_description = "钟声会在固定时刻穿过雾城。教堂表面的宁静下，藏着可供调查的档案、仪式禁忌与组织关系。"
interaction_prompt = "按 E 查看教堂"

[node name="Cemetery" parent="Locations" instance=ExtResource("5_location")]
position = Vector2(-800, 835)
location_id = "cemetery"
location_name = "墓园"
location_description = "潮湿的墓园远离主街，埋葬着没有名字的人。这里适合接触死亡传闻，也适合让危险在夜里发生。"
interaction_prompt = "按 E 查看墓园"

[node name="UndergroundBlackMarket" parent="Locations" instance=ExtResource("5_location")]
position = Vector2(820, 1120)
location_id = "underground_black_market"
location_name = "地下黑市"
location_description = "沿着运河边的石阶向下，便能找到没有招牌的入口。这里的钱更好赚，代价也从不写在价签上。"
interaction_prompt = "按 E 查看地下黑市"

