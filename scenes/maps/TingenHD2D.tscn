[node name="OldNeil" parent="WorldEntities/NPCs" instance=ExtResource("3_npc")]
position = Vector2(760, -635)
npc_name = "老尼尔"
dialogue_text = "你终于来了。\n这起死亡案不像普通谋杀，现场留下了很轻的灵性波动。\n先调查异常死亡现场，再用灵视找出被遮蔽的污染残留。之后用灵摆确认方向。"
quest_to_offer = "quest_tingen_become_seer"
interaction_prompt = "按 E 与老尼尔交谈"
schedule_id = "schedule_old_neil"

[node name="ConstableHale" parent="WorldEntities/NPCs" instance=ExtResource("3_npc")]
position = Vector2(760, 30)
npc_name = "黑尔警员"
dialogue_text = "白天的警察局永远不缺报案人。\n如果你想靠工作和委托积累经验，公告栏是一个不错的开始。"
quest_to_offer = ""
interaction_prompt = "按 E 与黑尔警员交谈"
schedule_id = "schedule_constable_hale"

[node name="MissElaine" parent="WorldEntities/NPCs" instance=ExtResource("3_npc")]
position = Vector2(-820, 35)
npc_name = "伊莲小姐"
dialogue_text = "俱乐部不出售答案，只交换观察。\n白天适合谈天气，夜晚适合谈梦境。"
quest_to_offer = ""
interaction_prompt = "按 E 与伊莲小姐交谈"
schedule_id = "schedule_miss_elaine"

