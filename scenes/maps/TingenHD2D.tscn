source_description = "一叠还带着油墨味的晚报被放在街角。你翻到招聘、失踪和教会公告版面，看到几条值得记下的消息。"
opportunity_ids = ["opp_newspaper_mysterious_death", "opp_newspaper_copyist_job", "opp_newspaper_missing_clerk", "opp_newspaper_river_auction", "opp_newspaper_church_notice"]
interaction_prompt = "按 E 阅读廷根晚报"

[node name="PoliceBulletinBoard" parent="WorldEntities/Interactables/OpportunitySources" instance=ExtResource("5_opportunity")]
position = Vector2(540, 30)
source_name = "警察局公告栏"
source_type = "bulletin_board"
source_description = "潮湿的木板上钉着正式委托、临时工作和一张被反复覆盖的悬赏。"
opportunity_ids = ["opp_board_police_assistant", "opp_board_pharmacy_apprentice", "opp_board_cemetery_reward"]
interaction_prompt = "按 E 查看公告栏"

[node name="ChurchNoticeBoard" parent="WorldEntities/Interactables/OpportunitySources" instance=ExtResource("5_opportunity")]
position = Vector2(475, 740)
source_name = "教会公告"
source_type = "bulletin_board"
