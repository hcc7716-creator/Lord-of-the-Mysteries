[node name="DivinationClubRegular" parent="WorldEntities/Interactables/OpportunitySources" instance=ExtResource("5_opportunity")]
position = Vector2(-625, 35)
source_name = "占卜俱乐部常客"
source_type = "npc_dialogue"
source_description = "一位戴着旧礼帽的常客注意到你的目光。他不愿透露姓名，但愿意用一句传闻交换耐心的倾听。"
opportunity_ids = ["opp_npc_divination_rumor"]
interaction_prompt = "按 E 与俱乐部常客交谈"

[node name="DockWorker" parent="WorldEntities/Interactables/OpportunitySources" instance=ExtResource("5_opportunity")]
position = Vector2(1080, 200)
